            }
        },
        {
            "type": "Replace",
            "file": "Stalker2/Content/GameLite/GameData/ItemPrototypes/QuestItemPrototypes.cfg",
            "value": {
                "old": "EEffectDisplayType::EffectLevel",
                "new": "EEffectDisplayType::Value"
            }
        }
    ]
}
